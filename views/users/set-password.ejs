<% layout("/layouts/boilerplate.ejs") %>

<body>
  <div class="row mt-3">
    <div class="col-12 col-sm-10 col-md-6 col-lg-4 mx-auto">
      <div class="auth-card">
        <h4 class="mb-2">Create Password</h4>
        <p class="text-muted mb-3">Welcome <b><%= user.firstName %> <%= user.lastName %></b>. Create a strong password to finish registration.</p>

        <form action="/signup/password" method="post" novalidate class="needs-validation">
          <input type="hidden" name="username" value="<%= user.username %>" />
          <div class="mb-3">
            <label for="password" class="form-label">Strong Password:</label>
            <input
              type="password"
              name="password"
              id="password"
              placeholder="At least 8 chars, uppercase, lowercase, number, symbol"
              class="form-control"
              minlength="8"
              required
            />
            <div class="form-text">Use at least 8 characters with uppercase, lowercase, a number, and a symbol.</div>
            <div class="invalid-feedback">Please enter a strong password.</div>
          </div>

          <button class="btn btn-success mt-2 w-100" type="submit">Create Password</button>
        </form>
      </div>
    </div>
  </div>
</body>
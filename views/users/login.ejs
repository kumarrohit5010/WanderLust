
<% layout("/layouts/boilerplate.ejs") %>

<body>
    <div class="row mt-3">
  <div class="col-12 col-sm-10 col-md-6 col-lg-4 mx-auto">
  <div class="auth-card">
     <h4 class="mb-3">Login</h4>
    <form action="/login" method="post" novalidate class="needs-validation">
      <div class="mb-3">
        <label for="username" class="form-label">Email :</label>
        <input
          type="text"
          name="username"
          id="username"
          placeholder="Enter  Email: "
          class="form-control"
          required
        />
      </div>

      <div class="mb-3">
        <label for="password" class="form-label">Password:</label>
        <input
          type="password"
          name="password"
          id="password"
          placeholder="Enter  Password: "
          class="form-control"
          required
        />
      </div>

      <div class="d-flex justify-content-end mb-3">
        <a href="/forgot-password" class="small text-decoration-none fw-semibold">Forgot password?</a>
      </div>

      <button class="btn btn-success mt-3 w-100" type="submit">Login</button>
    </form>
    </div>
  </div>
</div>
</body>
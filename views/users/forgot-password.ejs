<% layout("/layouts/boilerplate.ejs") %>

<body>
  <div class="row mt-3">
    <div class="col-12 col-sm-10 col-md-6 col-lg-4 mx-auto">
      <div class="auth-card">
        <h4 class="mb-2">Forgot Password</h4>
        <p class="text-muted mb-3">Enter your email address and we will send a reset OTP.</p>

        <form action="/forgot-password" method="post" novalidate class="needs-validation">
          <div class="mb-3">
            <label for="email" class="form-label">Email:</label>
            <input
              type="email"
              name="email"
              id="email"
              placeholder="Enter Email Address"
              class="form-control"
              autocomplete="email"
              required
            />
            <div class="invalid-feedback">Please enter a valid email address.</div>
          </div>

          <button class="btn btn-success mt-2 w-100" type="submit">Send Reset OTP</button>
        </form>

        <div class="text-center mt-3">
          <a href="/login" class="small text-decoration-none">Back to login</a>
        </div>
      </div>
    </div>
  </div>
</body>
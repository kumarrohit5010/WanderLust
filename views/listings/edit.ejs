                            <option value="Iconic Cities" <%= listing.catogery === 'Iconic Cities' ? 'selected' : '' %>>Iconic Cities</option>
                            <option value="Mountain" <%= listing.catogery === 'Mountain' ? 'selected' : '' %>>Mountain</option>
                            <option value="Castles" <%= listing.catogery === 'Castles' ? 'selected' : '' %>>Castles</option>
                            <option value="Swimming" <%= listing.catogery === 'Swimming' ? 'selected' : '' %>>Swimming</option>
                            <option value="farm" <%= listing.catogery === 'farm' ? 'selected' : '' %>>farm</option>
                            <option value="Camping" <%= listing.catogery === 'Camping' ? 'selected' : '' %>>Camping</option>
                            <option value="Arctic" <%= listing.catogery === 'Arctic' ? 'selected' : '' %>>Arctic</option>
                            <option value="Dome" <%= listing.catogery === 'Dome' ? 'selected' : '' %>>Dome</option>
                            <option value="Boat" <%= listing.catogery === 'Boat' ? 'selected' : '' %>>Boat</option>
                        </select>

                        <div class="invalid-feedback">
                            Category should be Valid.
                        </div>
                        <div class="valid-feedback">
                            Your selected category is valid.
                        </div>
                    </div>

        <button class="btn btn-dark mb-3 edit-btn">Submit</button>
    </form>
        </div>
    </div>

  <div  class="col-8 offset-2">
    <h5 class="mb-2">location Map:</h5>
    <div id="map" style="width:100%;height:500px;"></div>
  </div>

  

<script src="/js/map.js"></script>
    
    
